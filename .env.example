# Frontend (Next.js) - use .env.local. For Vercel production, set this in Project Settings → Environment Variables to your deployed API URL (e.g. https://your-api.railway.app) with no trailing slash.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Backend - use in server/.env
DATABASE_URL=postgresql://user:password@localhost:5432/finance_tracker
JWT_SECRET=your-super-secret-jwt-key-change-in-production
PORT=4000
NODE_ENV=development
